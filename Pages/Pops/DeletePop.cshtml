@page
@model Funkollection.Pages.Pops.DeletePopModel
@{
}

<h1>Are you sure you want to delete this Funko Pop?</h1>

<form method="post">
    <div>
        <p><strong>@Model.FunkoPop.Name</strong> will be deleted.</p>
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <a href="/Collection" class="btn btn-secondary">Cancel</a>
    </div>
</form>
