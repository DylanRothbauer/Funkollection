@page
@model IndexModel
@{
    ViewData["Title"] = "Welcome";
}

@if (User.Identity.IsAuthenticated)
{
    <h1>Welcome back, @User.Identity.Name!</h1>
    <p>Here’s your personalized content.</p>
    <a class="btn btn-primary" asp-page="/Dashboard">Go to Dashboard</a>
}
else
{
    <h1>Welcome to Funkollection!</h1>
    <p>Please log in to access your collection.</p>
    <a class="btn btn-success" asp-area="Identity" asp-page="/Account/Login">Login</a>
    <a class="btn btn-secondary" asp-area="Identity" asp-page="/Account/Register">Register</a>
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>


